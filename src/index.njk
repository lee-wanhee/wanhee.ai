---
layout: base
---
<section class="intro">
  <p>
    I work on <strong>foundation models for spatial and physical intelligence</strong>.
    I'm a PhD candidate in the NeuroAI Lab at Stanford University, advised by
    <a href="{{ site.advisor }}">Dan Yamins</a>. My older site is archived
    <a href="{{ site.oldsite }}">here</a>.
  </p>
</section>

<section class="posts">
  <h2 class="section-title">Writing</h2>
  {% if collections.posts.length %}
    {% for post in collections.posts %}
      <article class="post-item">
        <div class="post-meta">{{ post.date | readableDate }} · {{ post.templateContent | readingTime }} min read</div>
        <h3 class="post-item-title"><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
        {% if post.data.description %}<p class="excerpt">{{ post.data.description }}</p>{% endif %}
      </article>
    {% endfor %}
  {% else %}
    <p class="muted">Coming soon.</p>
  {% endif %}
</section>
